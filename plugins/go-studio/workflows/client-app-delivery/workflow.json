{
  "id": "client-app-delivery",
  "name": "Client App Delivery",
  "description": "Full delivery workflow for a new Go SaaS client app: scaffold → auth → services → payments → smoke test.",
  "nodes": {
    "start": {
      "type": "start",
      "name": "Start",
      "description": "Begin client app delivery. Confirm appName, modulePath, dbName with user. Resolve projectDir."
    },
    "scaffold": {
      "type": "task",
      "name": "Scaffold App",
      "description": "Read plugins/go-studio/skills/scaffold-app/SKILL.md and follow its steps.",
      "stage": "planning"
    },
    "scaffold_verify": {
      "type": "gate",
      "name": "Verify Scaffold",
      "description": "Run go build ./... in the new project. Pass only if build succeeds.",
      "stage": "verification",
      "maxRetries": 2
    },
    "build_auth": {
      "type": "task",
      "name": "Build Auth",
      "description": "Read plugins/go-studio/skills/build-auth/SKILL.md and follow its steps.",
      "stage": "development"
    },
    "auth_verify": {
      "type": "gate",
      "name": "Verify Auth",
      "description": "Run go build ./... and templ generate. Pass only if both succeed.",
      "stage": "verification",
      "maxRetries": 2
    },
    "build_features": {
      "type": "task",
      "name": "Build Domain Services",
      "description": "For each feature the user specified: read plugins/go-studio/skills/build-service/SKILL.md and build the service. Use SetItems for multiple features.",
      "stage": "development"
    },
    "features_verify": {
      "type": "gate",
      "name": "Verify Features",
      "description": "Run go build ./... — all services must compile.",
      "stage": "verification",
      "maxRetries": 2
    },
    "build_payments": {
      "type": "task",
      "name": "Build Stripe Payments",
      "description": "Read plugins/go-studio/skills/build-stripe/SKILL.md and follow its steps.",
      "stage": "development"
    },
    "payments_verify": {
      "type": "gate",
      "name": "Verify Payments",
      "description": "Run go build ./... — billing handler and webhook must compile.",
      "stage": "verification",
      "maxRetries": 2
    },
    "smoke_test": {
      "type": "task",
      "name": "Smoke Test",
      "description": "Read plugins/go-studio/skills/smoke-test/SKILL.md and follow its steps.",
      "stage": "verification"
    },
    "end_success": {
      "type": "end",
      "result": "success",
      "name": "App Delivered",
      "description": "App is scaffolded, auth is working, features are built, payments are integrated. Commit with: 'feat: initial {appName} delivery'"
    },
    "hitl_blocked": {
      "type": "end",
      "result": "blocked",
      "escalation": "hitl",
      "name": "Blocked",
      "description": "A step failed and could not be automatically resolved. Review the error and decide how to proceed."
    }
  },
  "edges": [
    { "from": "start", "to": "scaffold" },
    { "from": "scaffold", "to": "scaffold_verify" },
    { "from": "scaffold_verify", "to": "build_auth", "on": "passed", "label": "Project compiles" },
    { "from": "scaffold_verify", "to": "scaffold", "on": "failed", "label": "Fix scaffold errors" },
    { "from": "scaffold_verify", "to": "hitl_blocked", "on": "exhausted", "label": "Scaffold exhausted retries" },
    { "from": "build_auth", "to": "auth_verify" },
    { "from": "auth_verify", "to": "build_features", "on": "passed", "label": "Auth compiles" },
    { "from": "auth_verify", "to": "build_auth", "on": "failed", "label": "Fix auth errors" },
    { "from": "auth_verify", "to": "hitl_blocked", "on": "exhausted", "label": "Auth exhausted retries" },
    { "from": "build_features", "to": "features_verify" },
    { "from": "features_verify", "to": "build_payments", "on": "passed", "label": "Features compile" },
    { "from": "features_verify", "to": "build_features", "on": "failed", "label": "Fix feature errors" },
    { "from": "features_verify", "to": "hitl_blocked", "on": "exhausted", "label": "Features exhausted retries" },
    { "from": "build_payments", "to": "payments_verify" },
    { "from": "payments_verify", "to": "smoke_test", "on": "passed", "label": "Payments compile" },
    { "from": "payments_verify", "to": "build_payments", "on": "failed", "label": "Fix payment errors" },
    { "from": "payments_verify", "to": "hitl_blocked", "on": "exhausted", "label": "Payments exhausted retries" },
    { "from": "smoke_test", "to": "end_success", "on": "passed", "label": "App renders correctly" },
    { "from": "smoke_test", "to": "hitl_blocked", "on": "failed", "label": "Smoke test failed" }
  ]
}
